
Перем Контейнер Экспорт; // Массив из Число
Перем Сложно Экспорт; // см. НовыйСложно

Процедура ПриСозданииОбъекта()
	Контейнер = Новый Массив;
	Сложно = НовыйСложно();
КонецПроцедуры

// Коечто
//
//  Возвращаемое значение:
//   Структура:
//		* СЧислом - Число -
//		* СТекстом - Строка -
//
Функция НовыйСложно()
	Возврат Новый Структура("СЧислом, СТекстом", 0, "");
КонецФункции
