// Композит с переносом значения ПО УМОЛЧАНИЮ (ПереноситьЗначениеПоУмолчанию = Истина):
// если значение не передано, в &Пластилин переносится значение по умолчанию ("Логгер").
&Аннотация("ВнедрениеПоУмолчанию")
&Пластилин
Процедура ПриСозданииОбъекта(
	&ПсевдонимДля(Аннотация = "Пластилин", Параметр = "Значение", ПереноситьЗначениеПоУмолчанию = Истина)
	Значение = "Логгер"
)
КонецПроцедуры
