// killjoy-алиас &Внедряемое = &Пластилин. Значение/Тип декларативно переносятся в
// подчинённый &Пластилин через &ПсевдонимДля (как в реальном autumn-killjoy-flavour 1.3+).
&Аннотация("Внедряемое")
&Пластилин
Процедура ПриСозданииОбъекта(
	&ПсевдонимДля(Аннотация = "Пластилин", Параметр = "Значение") Значение = "",
	&ПсевдонимДля(Аннотация = "Пластилин", Параметр = "Тип") Тип = ""
)
КонецПроцедуры
