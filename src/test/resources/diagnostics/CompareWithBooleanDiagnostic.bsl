Процедура Тест(Значение)
    Флаг = (Значение = 1);

    // срабатывает: булева переменная сравнивается с Истина
    Если Флаг = Истина Тогда
        Возврат;
    КонецЕсли;

    // срабатывает: булева переменная сравнивается с Ложь (порядок операндов не важен)
    Если Ложь = Флаг Тогда
        Возврат;
    КонецЕсли;

    // срабатывает: обе стороны - булевы литералы
    Если Истина = Ложь Тогда
        Возврат;
    КонецЕсли;

    // не срабатывает: тип параметра не выводится, сравнение может быть обоснованным
    Если Значение = Истина Тогда
        Возврат;
    КонецЕсли;

    // не срабатывает: нет сравнения с булевым литералом
    Если Значение = 1 Тогда
        Возврат;
    КонецЕсли;

    // не срабатывает: тип - объединение (Булево | Строка), сравнение обосновано
    Если Значение Тогда
        Результат = Истина;
    Иначе
        Результат = "Нет";
    КонецЕсли;
    Если Результат = Истина Тогда
        Возврат;
    КонецЕсли;
КонецПроцедуры
