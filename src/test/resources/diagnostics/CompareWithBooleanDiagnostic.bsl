Процедура Тест(Значение)
    Если Значение = Истина Тогда // замечание
        Возврат;
    КонецЕсли;

    Если Значение <> Ложь Тогда // замечание
        Возврат;
    КонецЕсли;

    Если Истина = Значение Тогда // замечание
        Возврат;
    КонецЕсли;

    Если Значение Тогда // без замечания
        Возврат;
    КонецЕсли;

    Если Значение = 1 Тогда // без замечания
        Возврат;
    КонецЕсли;
КонецПроцедуры
