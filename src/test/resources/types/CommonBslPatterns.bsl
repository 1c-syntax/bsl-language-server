// Возвращаемое значение:
//  Структура - Имя - Строка, Возраст - Число
//
Функция СоздатьПараметры() Экспорт
	Параметры = Новый Структура;
	Параметры.Вставить("Имя", "Иван");
	Параметры.Вставить("Возраст", 30);
	Возврат Параметры;
КонецФункции

// Возвращаемое значение:
//  ТаблицаЗначений - таблица с колонками Идентификатор и Сумма
//
Функция СформироватьТЗ() Экспорт
	ТЗ = Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("Идентификатор", Новый ОписаниеТипов("Строка"));
	ТЗ.Колонки.Добавить("Сумма", Новый ОписаниеТипов("Число"));
	Возврат ТЗ;
КонецФункции

Процедура Использование()
	Парам = СоздатьПараметры();
	ИмяПолучено = Парам.Имя;
	ВозрастПолучено = Парам.Возраст;

	ТЗ = СформироватьТЗ();
	Для Каждого Стр Из ТЗ Цикл
		ИдИзСтр = Стр.Идентификатор;
		СуммаИзСтр = Стр.Сумма;
	КонецЦикла;

	// Перебор массива с известным типом.
	Список = Новый Массив;
	Список.Добавить("первый");
	Список.Добавить("второй");

	Для Каждого Эл Из Список Цикл
		ТипЭл = Эл;
	КонецЦикла;

	// Индекс-доступ на массиве.
	Первый = Список[0];

	// Цепочка через метод массива возвращающий копию.
	Копия = Список.Скопировать();
	Копия.Добавить("третий");

	// Вложенные структуры.
	Внешняя = Новый Структура("Имя, Внутр", "тест", Новый Структура("ВнутрПоле", 100));
	ВнутрЗнач = Внешняя.Внутр;
	ВнутрПоле = ВнутрЗнач.ВнутрПоле;
КонецПроцедуры
