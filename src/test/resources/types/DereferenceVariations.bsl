Процедура Тест()
	// Dereference на разных типах.
	С = Новый Структура;
	С.Вставить("Поле1", 100);
	С.Вставить("Поле2", "значение");

	// Прямой dereference.
	А = С.Поле1;

	// Dereference после индекса.
	М = Новый Массив;
	М.Добавить(С);
	БотМ = М[0].Поле1;

	// Dereference на результат тернарного.
	НеЛибо = Истина;
	ТерС = ?(НеЛибо, С, Новый Структура("Поле1", 200));
	ТерЗнач = ТерС.Поле1;

	// Dereference на результат метода с возвратом.
	Карта = Новый Соответствие;
	Карта.Вставить("К", С);
	ИзКарты = Карта["К"];
	ПолеИзКарты = ИзКарты.Поле1;

	// Глубокий dereference.
	Внеш = Новый Структура;
	Внутр = Новый Структура;
	Внутр.Вставить("Глубокий", 999);
	Внеш.Вставить("Уровень1", Внутр);
	ГлубЗнач = Внеш.Уровень1.Глубокий;

	// Dereference на UNKNOWN type.
	НеЗнаемЧтоЭто = НеОпределеноСнаружи;
	ЗнЧегоТо = НеЗнаемЧтоЭто.НесуществующееПоле;

	// Цепочка вызовов с dereference.
	Стр1 = Новый Структура("ID, Список", 1, Новый Массив);
	Стр1.Список.Добавить("элемент");
	Эл = Стр1.Список[0];

	// Dereference на результат конструктора.
	НоваяСтр = Новый Структура("X", 42);
	Икс = НоваяСтр.X;

	// Index access on result of method.
	НовМ = Новый Массив;
	НовМ.Добавить("a");
	НовМ.Добавить("b");
	КопМ = НовМ.Скопировать();
	ЭлКоп = КопМ[0];

	// Index access on Соответствие через комплексное выражение ключа.
	ИндексМ = Карта[Строка("К")];
КонецПроцедуры
