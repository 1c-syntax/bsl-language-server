// Создаёт пустой массив.
//
//  Возвращаемое значение:
//   Массив - новый массив.
//
Функция СоздатьМассив() Экспорт
    Возврат Новый Массив;
КонецФункции

// Возвращает структуру с метаданными.
//
//  Возвращаемое значение:
//   Структура - метаданные.
//
Функция ПолучитьСтруктуру() Экспорт
    Возврат Новый Структура;
КонецФункции

КоличествоЭлементов = СоздатьМассив().Количество();
ВложенноеКоличество = СоздатьМассив().Получить(0);
КоличествоПолей = ПолучитьСтруктуру().Количество();

