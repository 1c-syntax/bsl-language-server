Процедура Тест()
	// If-Then-Else.
	Знач = 10;
	Если Знач > 5 Тогда
		Результат = "большое";
	ИначеЕсли Знач > 0 Тогда
		Результат = "малое";
	Иначе
		Результат = "отрицательное";
	КонецЕсли;

	// Try-Catch.
	Попытка
		Х = 10 / 0;
	Исключение
		ИнфОшибки = ИнформацияОбОшибке();
	КонецПопытки;

	// For loop with index.
	Сумма = 0;
	Для Сч = 1 По 10 Цикл
		Сумма = Сумма + Сч;
	КонецЦикла;

	// While loop.
	Й = 0;
	Пока Й < 5 Цикл
		Й = Й + 1;
	КонецЦикла;

	// For-each over various collections.
	Массив = Новый Массив;
	Массив.Добавить(1);
	Для Каждого Элем Из Массив Цикл
		ТипЭлемента = Элем;
	КонецЦикла;

	// Switch-like через If chain.
	КодСтатуса = 200;
	Если КодСтатуса = 200 Тогда
		Описание = "OK";
	ИначеЕсли КодСтатуса = 404 Тогда
		Описание = "Not Found";
	ИначеЕсли КодСтатуса = 500 Тогда
		Описание = "Internal Error";
	Иначе
		Описание = "Unknown";
	КонецЕсли;

	// Nested if.
	Параметры = Новый Структура;
	Если Параметры.Свойство("Имя") Тогда
		ИмяПар = Параметры.Имя;
		Если ЗначениеЗаполнено(ИмяПар) Тогда
			ОбработатьИмя(ИмяПар);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Процедура ОбработатьИмя(И)
КонецПроцедуры
