Процедура Тест()
	Параметры = Новый Структура;
	Параметры.Вставить("Имя", "Иван");
	Параметры.Вставить("Возраст", 42);
	// Вставить с одним аргументом — значение по умолчанию Неопределено (L853).
	Параметры.Вставить("ТолькоКлюч");
	// Вставить с пустым ключом — пропускается (L845-846).
	Параметры.Вставить("");
	// Вставить без аргументов (незавершённый набор) — пропускается, без NPE.
	Параметры.Вставить();
	X = Параметры.Имя;
	Y = Параметры.Возраст;
	Z = Параметры.ТолькоКлюч;
КонецПроцедуры
