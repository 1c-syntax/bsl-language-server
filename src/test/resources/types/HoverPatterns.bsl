// Параметры:
//  Х - Число - входное число
//
// Возвращаемое значение:
//  Число - результат
//
Функция Удвоить(Х) Экспорт
	Возврат Х * 2;
КонецФункции

// Параметры:
//  Имя - Строка - имя пользователя
//  Возраст - Число - возраст
//
Процедура СохранитьПользователя(Имя, Возраст) Экспорт
	Парам = Новый Структура;
	Парам.Вставить("Имя", Имя);
	Парам.Вставить("Возраст", Возраст);
КонецПроцедуры

// Возвращаемое значение:
//  Структура
//   * ID - Число
//   * Название - Строка
//
Функция СоздатьСвернутыйОбъект() Экспорт
	Объект = Новый Структура("ID, Название", 1, "Тест");
	Возврат Объект;
КонецФункции

Процедура ИспользоватьГдеТо()
	// hover на Удвоить должен показывать сигнатуру.
	Результат = Удвоить(5);

	// hover на параметре Имя должен показывать тип Строка.
	СохранитьПользователя("Иван", 30);

	// hover на returnType функции.
	Свертка = СоздатьСвернутыйОбъект();
	Идентификатор = Свертка.ID;
	НаименОбъекта = Свертка.Название;

	// hover на платформенном методе.
	Стр = "пример";
	Длина = СтрДлина(Стр);

	// Hover on Новый Структура.
	Карта = Новый Структура;
