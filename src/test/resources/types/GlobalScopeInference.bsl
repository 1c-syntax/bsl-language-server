Процедура Тест()
	// Имя класса как идентификатор — НЕ должно инферить тип
	// (TYPE_NAME role фильтруется в inferIdentifier).
	КлассКакИдентификатор = Структура;

	// Глобальный SyntheticSymbol с valueType=Boolean — Истина возвращает Булево.
	// Это покрывает inferIdentifier через GlobalScopeProvider.findGlobalEntry → SyntheticSymbol.
	БулевоИзГлобала = Истина;

	// Идентификатор, который не резолвится ни через reference, ни через GlobalScope.
	ПустойРезолв = НесуществующийГлобал;

	// Двойной унарный минус — Число.
	ДвойнойМинус = --10;

	// Тернарный оператор — union типов веток.
	Тернарный = ?(Истина, "string", 42);

	// Глобальный property — КодировкаТекста должна резолвиться через GlobalSymbolScope.
	Кодировка = КодировкаТекста;

	// Глобальная функция (PLATFORM_GLOBAL_METHOD) как identifier-ссылка (не вызов).
	// L299 filter в inferIdentifier должен отсечь PLATFORM_GLOBAL_METHOD.
	ССылкаНаГлобал = Сообщить;

	// Перечисление (PLATFORM_GLOBAL_ENUM) — должно резолвиться.
	ЕнумПерем = НаправлениеПоиска;

	// Сложение даты со числом — Дата.
	ДатаПлюсЧисло = '20200101' + 3600;

	// Сравнение строк.
	СравнСтрок = "abc" = "abc";

	// Логические со сложными выражениями.
	СложноеЛог = (1 > 0) И (Истина ИЛИ Ложь);
КонецПроцедуры
