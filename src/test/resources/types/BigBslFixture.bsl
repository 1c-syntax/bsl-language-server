// Возвращаемое значение:
//  Массив - список чисел
//
Функция СоздатьСписокЧисел() Экспорт
	Результат = Новый Массив;
	Результат.Добавить(1);
	Результат.Добавить(2);
	Возврат Результат;
КонецФункции

// Параметры:
//  Источник - Массив - входной список
//  Множитель - Число - на что умножать
//
// Возвращаемое значение:
//  Массив - результат
//
Функция УмножитьЭлементы(Источник, Множитель) Экспорт
	Результат = Новый Массив;
	Для Каждого Элемент Из Источник Цикл
		ПромежЗнач = Элемент;
		ОбработанноеЗначение = ПромежЗнач;
		Результат.Добавить(ОбработанноеЗначение);
	КонецЦикла;
	Возврат Результат;
КонецФункции

// Параметры:
//  Документ - См. СоздатьСписокЧисел
//
Процедура ОбработатьСписок(Документ) Экспорт
	ПерваяСтрока = Документ[0];
	КолВо = Документ.Количество();
	Сообщить(КолВо);
КонецПроцедуры

Процедура ОсновнаяЛогика()
	// Структура с разными типами ключей.
	ПараметрыЗапроса = Новый Структура("Имя, Возраст, Активен", "Иван", 30, Истина);
	ИмяПар = ПараметрыЗапроса.Имя;
	ВозрастПар = ПараметрыЗапроса.Возраст;
	АктивПар = ПараметрыЗапроса.Активен;

	// ТЗ с типизированными колонками.
	ТЗДанных = Новый ТаблицаЗначений;
	ТЗДанных.Колонки.Добавить("Идентификатор", Новый ОписаниеТипов("УникальныйИдентификатор"));
	ТЗДанных.Колонки.Добавить("Название", Новый ОписаниеТипов("Строка"));
	ТЗДанных.Колонки.Добавить("Сумма", Новый ОписаниеТипов("Число"));

	НоваяСтрока = ТЗДанных.Добавить();
	НоваяСтрока.Название = "Тестовое имя";
	НоваяСтрока.Сумма = 100;

	Для Каждого СтрокаТЗ Из ТЗДанных Цикл
		Ид = СтрокаТЗ.Идентификатор;
		Назв = СтрокаТЗ.Название;
		ТекСумма = СтрокаТЗ.Сумма;
	КонецЦикла;

	// Соответствие с разными типами значений.
	Карта = Новый Соответствие;
	Карта.Вставить("text", "hello");
	Карта.Вставить("count", 42);
	Карта.Вставить("flag", Ложь);

	ТекстИзКарты = Карта["text"];
	СчётчикИзКарты = Карта["count"];

	// Цикл по парам соответствия.
	Для Каждого КЗ Из Карта Цикл
		КлючКЗ = КЗ.Ключ;
		ЗначКЗ = КЗ.Значение;
	КонецЦикла;

	// Цикл по структуре.
	Для Каждого КЗС Из ПараметрыЗапроса Цикл
		КлючС = КЗС.Ключ;
		ЗначС = КЗС.Значение;
	КонецЦикла;

	// ФиксированныеВарианты — конструкторы.
	ФиксС = Новый ФиксированнаяСтруктура(ПараметрыЗапроса);
	ФиксМ = Новый ФиксированноеСоответствие(Карта);
	ФиксА = Новый ФиксированныйМассив(СоздатьСписокЧисел());

	// Чтение фиксированных значений.
	ИмяФикс = ФиксС.Имя;
	ЭлементФиксА = ФиксА[0];

	// Тернарный с сложными ветками.
	Ветка = ?(КолВо > 0, ПараметрыЗапроса, Новый Структура);

	// Цепочка через метод, возвращающий массив.
	КопияСписка = СоздатьСписокЧисел();
	КопияСписка.Добавить(99);
	ПоследнийЭл = КопияСписка[КопияСписка.ВГраница()];

	// Передача в типизированный параметр.
	Умн = УмножитьЭлементы(КопияСписка, 2);
КонецПроцедуры

