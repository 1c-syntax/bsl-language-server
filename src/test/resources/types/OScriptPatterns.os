// OneScript module-level variables and functions.
Перем СтатусМодуля Экспорт;

// Параметры:
//  X - Строка - имя пользователя
//
// Возвращаемое значение:
//  Строка - приветствие
//
Функция Приветствовать(X) Экспорт
	Возврат "Hello, " + X;
КонецФункции

Процедура Обработать()
	// String concatenation.
	Имя = "Иван";
	Привет = Приветствовать(Имя);

	// Различные платформенные типы.
	Список = Новый Массив;
	Список.Добавить("первый");
	Список.Добавить("второй");

	Карта = Новый Соответствие;
	Карта.Вставить("ключ", "значение");

	Стр = Новый Структура("Имя, Возраст", "Иван", 30);
	ПолучИмя = Стр.Имя;
	ПолучВозраст = Стр.Возраст;

	// Тип() function.
	ТипЧисла = Тип("Число");

	// Date.
	Сегодня = Новый Дата(2020, 1, 1);

	// Глобальные функции (OneScript-specific).
	СтрПривет = Строка(123);
	НеЧисло = Число("456");
КонецПроцедуры
