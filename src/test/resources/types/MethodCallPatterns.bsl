// Параметры:
//  С - Строка
//
// Возвращаемое значение:
//  Число
//
Функция ОбработатьИВернутьЧисло(С) Экспорт
	Возврат СтрДлина(С);
КонецФункции

// Параметры:
//  Н - Число
//
// Возвращаемое значение:
//  Массив
//
Функция СоздатьСписокНомеров(Н) Экспорт
	Результат = Новый Массив;
	Для Сч = 1 По Н Цикл
		Результат.Добавить(Сч);
	КонецЦикла;
	Возврат Результат;
КонецФункции

// Возвращаемое значение:
//  Структура
//
Функция СформироватьПараметры() Экспорт
	Парам = Новый Структура;
	Парам.Вставить("Имя", "Иван");
	Парам.Вставить("Возраст", 30);
	Возврат Парам;
КонецФункции

Процедура Использование()
	// Вызов с литералом аргумента.
	Длина1 = ОбработатьИВернутьЧисло("слово");

	// Вызов с переменной.
	Текст = "пример текста";
	Длина2 = ОбработатьИВернутьЧисло(Текст);

	// Вызов с конкатенацией.
	Длина3 = ОбработатьИВернутьЧисло("a" + "b" + "c");

	// Вызов с вложенным вызовом.
	Длина4 = ОбработатьИВернутьЧисло(Строка(123));

	// Цепочка вызовов.
	Список = СоздатьСписокНомеров(5);
	Кол = Список.Количество();

	// Цепочка через chain method.
	Копия = Список.Скопировать();

	// Вызов с конструктором как аргументом.
	ОбработатьСтруктуру(Новый Структура("X", 1));

	// Вызов из другого вызова.
	Параметры = СформироватьПараметры();
	ИмяП = Параметры.Имя;
	ВозрастП = Параметры.Возраст;

	// Передача в platform call.
	Сообщить(Параметры);
КонецПроцедуры

