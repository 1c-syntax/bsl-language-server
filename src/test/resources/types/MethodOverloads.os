// Тест выбора подходящего варианта вызова метода (overload).
// ЧтениеДанных.Разделить имеет 2 варианта: 1 параметр и 2 параметра.
Чтение = Новый ЧтениеДанных("path");
Часть1 = Чтение.Разделить("|");          // 1 аргумент -> 1-й вариант
Часть2 = Чтение.Разделить("|", "UTF-8"); // 2 аргумента -> 2-й вариант
