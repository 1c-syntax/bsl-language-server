// Глобальная функция (СтрНайти) с несколькими параметрами — на ней ждём
// inlay-метки имён параметров.
Поз = СтрНайти("abc", "b", НаправлениеПоиска.СНачала, 1);

// Вызов метода через точку (Массив.Вставить) — параметризованный.
М = Новый Массив();
М.Вставить(0, "x");

// Конструктор с параметрами — Новый Массив(N).
БольшойМассив = Новый Массив(10);

// Вызов с аргументом, чьё значение содержит имя параметра — supplier
// должен скрыть hint, чтобы не дублировать «Имя_параметра: Имя_параметра».
СтрНайти("СтрокаПоиска", "ПодстрокаПоиска");

// Конструктор с пустым доводом — supplier не показывает hint на blank.
ПустойМассив = Новый Массив();

// Конструктор Структура с двумя параметрами — должны быть hints на оба
// параметра.
СтрС2Парам = Новый Структура("Имя, Фамилия", "Иван", "Иванов");

// Перегруженный конструктор — Массив(2, 3) — variadic-вариант.
МноГомерный = Новый Массив(2, 3);

// Конструктор Массив(ФиксированныйМассив) — type-aware pick по типу аргумента.
ФМ = Новый ФиксированныйМассив(Новый Массив(5));
КопияИзФМ = Новый Массив(ФМ);

// Конструктор неизвестного типа — supplier пропускает.
Неизв = Новый НетТакогоТипа123(1, 2);

// Глобальная функция с одним из параметров, чьё имя совпадает с en-вариантом.
Стр = ПодстрокаДляПоиска();
Поз2 = СтрНайти(Стр, "x");

// methodCall где receiver — выражение без типа.
Локальная = Стр.Substring(0, 5);

Функция ПодстрокаДляПоиска() Экспорт
	Возврат "hello world";
КонецФункции
