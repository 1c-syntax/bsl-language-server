// Глобальная функция (СтрНайти) с несколькими параметрами — на ней ждём
// inlay-метки имён параметров.
Поз = СтрНайти("abc", "b", НаправлениеПоиска.СНачала, 1);

// Вызов метода через точку (Массив.Вставить) — параметризованный.
М = Новый Массив();
М.Вставить(0, "x");

// Конструктор с параметрами — Новый Массив(N).
БольшойМассив = Новый Массив(10);

// Вызов с аргументом, чьё значение содержит имя параметра — supplier
// должен скрыть hint, чтобы не дублировать «Имя_параметра: Имя_параметра».
СтрНайти("СтрокаПоиска", "ПодстрокаПоиска");

// Конструктор с пустым доводом — supplier не показывает hint на blank.
ПустойМассив = Новый Массив();
