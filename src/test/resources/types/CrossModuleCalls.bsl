// Параметры:
//  Имя - Строка
//
// Возвращаемое значение:
//  Структура - { Имя: Строка, Активен: Булево }
//
Функция СоздатьПользователя(Имя) Экспорт
	Польз = Новый Структура;
	Польз.Вставить("Имя", Имя);
	Польз.Вставить("Активен", Истина);
	Возврат Польз;
КонецФункции

// Параметры:
//  Польз - См. СоздатьПользователя
//
Процедура ОбработатьПользователя(Польз) Экспорт
	Имя = Польз.Имя;
	Активен = Польз.Активен;
КонецПроцедуры

// Возвращаемое значение:
//  Массив - список из 3 пользователей
//
Функция СоздатьВсехПользователей() Экспорт
	Массив = Новый Массив;
	Массив.Добавить(СоздатьПользователя("Иван"));
	Массив.Добавить(СоздатьПользователя("Петр"));
	Массив.Добавить(СоздатьПользователя("Сидор"));
	Возврат Массив;
КонецФункции

Процедура Тест()
	// Простой вызов.
	Польз = СоздатьПользователя("Иван");
	Имя1 = Польз.Имя;
	Акт1 = Польз.Активен;

	// Вызов с передачей результата.
	ОбработатьПользователя(СоздатьПользователя("Петр"));

	// Цепочка вызовов.
	ВсеП = СоздатьВсехПользователей();
	КолВП = ВсеП.Количество();
	ПервП = ВсеП[0];
	ИмяПервП = ПервП.Имя;

	// Передача переменной в процедуру.
	ВтПольз = СоздатьПользователя("Анна");
	ОбработатьПользователя(ВтПольз);

	// Вложенные вызовы.
	НовПольз = СоздатьПользователя(СоздатьПользователя("Маша").Имя);
