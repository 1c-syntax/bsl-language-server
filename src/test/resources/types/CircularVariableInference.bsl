Процедура Тест()
	// Циркулярная зависимость: А = Б, Б = А. Recursion guard (ctx.visited)
	// должен предотвратить бесконечный цикл и вернуть EMPTY.
	А = Б;
	Б = А;
	X = А;

	// Type-комментарий после переменной — typesFromVariableTrailingComment.
	Тип1 = 0; // Число - возраст

	// Self-referencing с self-assignment.
	Сам = Сам;
	Y = Сам;
КонецПроцедуры

// Метод с JsDoc-параметром.
//
// Параметры:
//   Параметр - Строка - текст для обработки
//
Функция Обработать(Параметр) Экспорт
	Возврат Параметр;
КонецФункции

Процедура ВызватьМетод()
