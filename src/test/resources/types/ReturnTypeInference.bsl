// Возвращаемое значение:
//  Число
//
Функция ВернутьЧисло() Экспорт
	Возврат 42;
КонецФункции

// Возвращаемое значение:
//  Строка
//
Функция ВернутьСтроку() Экспорт
	Возврат "результат";
КонецФункции

// Возвращаемое значение:
//  Булево
//
Функция ВернутьБулево() Экспорт
	Возврат Истина;
КонецФункции

// Возвращаемое значение:
//  Массив
//
Функция ВернутьМассив() Экспорт
	Результат = Новый Массив;
	Результат.Добавить(1);
	Возврат Результат;
КонецФункции

// Возвращаемое значение:
//  Структура
//
Функция ВернутьСтруктуру() Экспорт
	Возврат Новый Структура("Поле", 1);
КонецФункции

// Несколько Возврат с разными типами — union.
Функция МножественныйВозврат(Условие) Экспорт
	Если Условие Тогда
		Возврат "строка";
	Иначе
		Возврат 42;
	КонецЕсли;
КонецФункции

// Без типа возврата в JsDoc.
Функция БезЯвногоТипа() Экспорт
	Возврат 100;
КонецФункции

Процедура Тест()
	Ч = ВернутьЧисло();
	С1 = ВернутьСтроку();
	Б = ВернутьБулево();
	М = ВернутьМассив();
	Стр = ВернутьСтруктуру();
	Мн = МножественныйВозврат(Истина);
	Бт = БезЯвногоТипа();
КонецПроцедуры
