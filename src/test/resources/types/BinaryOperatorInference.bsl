// Логические — Булево.
ЛогическоеИ = Истина И Ложь;
ЛогическоеИли = Истина Или Ложь;
Отрицание = НЕ Истина;

// Сравнения — Булево.
СравнениеРавно = 100 = 100;
СравнениеБольше = 500 > 300;
СравнениеНеравно = "abc" <> "def";

// Арифметика — Число.
Сумма = 200 + 300;
Разность = 500 - 200;
Произведение = 400 * 200;
Деление = 1000 / 200;
ОстатокОтДеления = 700 % 300;
Унарный = -100;

// Левый-Строка + что угодно → Строка.
СтрокаПлюсСтрока = "abc" + "def";
СтрокаПлюсЧисло = "пять " + 500;
// Левый-Число + Строка → Число (правый приводится к Числу).
ЧислоПлюсСтрока = 500 + " пять";

// Сложение дат — Дата.
ДатаПлюсСекунды = '20200101' + 86400;

// Тернарный — union типов веток.
УсловныйЧислоИлиСтрока = ?(Истина, 100, "строка");

// #4205: конкатенация строки с собой не должна расширять тип до Число —
// self-reference резолвится в уже известный тип (Строка), а не в EMPTY.
ИмяЧасть = "Джон ";
ФамилияЧасть = "Доу";
ПолноеИмя = ИмяЧасть + ФамилияЧасть;
ПолноеИмя = ПолноеИмя + "Загадочное";
ИтогИмя = ПолноеИмя;
// Числовой аккумулятор при этом остаётся Число (общая ветка `+` не тронута).
Счётчик = 0;
Счётчик = Счётчик + 1;
ИтогСчёт = Счётчик;
