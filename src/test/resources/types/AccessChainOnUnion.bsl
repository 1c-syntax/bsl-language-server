Процедура Тест()
	// Union из двух структур с разными полями.
	А = ?(Истина,
		Новый Структура("Поле1", 100),
		Новый Структура("Поле2", "значение"));

	// Доступ к разным полям union-типа.
	А1 = А.Поле1;
	А2 = А.Поле2;

	// Union массивов.
	М = ?(Истина, Новый Массив, Новый ФиксированныйМассив(Новый Массив));

	// Index access на union.
	Эл = М[0];

	// Цепочка вызовов на union.
	КолМ = М.Количество();

	// Глубокий union (3 ветки).
	Тр = ?(1 = 2, "string",
		?(1 = 3, 42, Истина));

	// Index access на ИЛИ возвращающее Дата или Строка.
	Сс = ?(Истина, '20200101', "строка");

	// Передача union в типизированную функцию.
	НаПарам = ?(Истина, 1, "two");
	ОбработатьЛюбойТип(НаПарам);
КонецПроцедуры

// Параметры:
//  П - Произвольный
//
Процедура ОбработатьЛюбойТип(П) Экспорт
КонецПроцедуры
