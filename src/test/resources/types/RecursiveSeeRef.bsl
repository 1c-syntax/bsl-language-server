Процедура Пример()
	Корень = ДеревоУзел();
	Узел = Корень.Потомки[0];
	Глубоко = Корень.Потомки[0].Потомки[0].Значение;
КонецПроцедуры

// Возвращаемое значение:
//  Структура:
//   * Значение - Строка - Значение узла.
//   * Потомки - Массив из см. ДеревоУзел - Дочерние узлы.
Функция ДеревоУзел() Экспорт
	Результат = Новый Структура;
	Результат.Вставить("Значение", "");
	Результат.Вставить("Потомки", Новый Массив);
