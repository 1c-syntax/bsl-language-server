// Сравнения — Булево. Используем многозначные числа для точности позиции курсора.
Сравн1 = 100 < 200;
Равно1 = 100 = 200;
НеРавно1 = 100 <> 200;
БольшеРавно1 = 100 >= 200;
МеньшеРавно1 = 100 <= 200;

// Тернарный с одинаковыми ветками.
ТернОднотип = ?(100 > 0, "A", "B");

// Тернарный с разными ветками — union.
ТернРазнотип = ?(100 > 0, "A", 42);

// Унарный NOT — Булево.
УнНОТ = НЕ Истина;

// Логические — Булево.
ЛогИ = Истина И Ложь;
ЛогИЛИ = Истина ИЛИ Ложь;
