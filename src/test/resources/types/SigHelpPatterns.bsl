// Параметры:
//  А - Число - первое слагаемое
//  Б - Число - второе слагаемое
//
// Возвращаемое значение:
//  Число - сумма
//
Функция Сложить(А, Б) Экспорт
	Возврат А + Б;
КонецФункции

// Параметры:
//  Имя - Строка
//  Параметры - Структура - опции
//  ИспользоватьКеш - Булево - опционально
//
Процедура НастроитьКомпонент(Имя, Параметры, ИспользоватьКеш = Истина) Экспорт
КонецПроцедуры

// Без параметров.
Процедура БезПарам() Экспорт
КонецПроцедуры

// С одним необязательным.
//
// Параметры:
//  Опц - Число - необязательный, default = 0
//
Функция ТолькоНеобязат(Опц = 0) Экспорт
	Возврат Опц;
КонецФункции

Процедура ВызватьВсё()
	Х1 = Сложить(10, 20);
	Х2 = Сложить(, );
	НастроитьКомпонент("comp1", Новый Структура);
	НастроитьКомпонент("comp2", Новый Структура, Ложь);
	БезПарам();
	Х3 = ТолькоНеобязат();
	Х4 = ТолькоНеобязат(100);

	// Вложенные вызовы.
	Х5 = Сложить(Сложить(1, 2), Сложить(3, 4));

	// Вызов как параметр в platform call.
	Сообщить(Сложить(5, 6));

	// platform-вызов с union типов.
	Стр = "пример";
	Сообщить(Стр);
	Сообщить("прямая строка");
КонецПроцедуры
