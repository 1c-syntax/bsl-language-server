Процедура Тест()
	// Methods on Structure (Структура).
	С = Новый Структура("X", 1);
	С.Очистить();
	С.Удалить("X");
	С.Вставить("Y", 2);
	КолС = С.Количество();

	// Methods on Map (Соответствие).
	М = Новый Соответствие;
	М.Вставить("К", 10);
	М.Удалить("К");
	М.Очистить();
	КолМ = М.Количество();
	Знач = М.Получить("К");

	// Methods on Array (Массив).
	А = Новый Массив;
	А.Добавить(1);
	А.Вставить(0, 5);
	А.Удалить(0);
	А.Сдвинуть(1, 2);
	НашлиИндекс = А.Найти(5);
	Перв = А.ВГраница();

	// Chain through method that returns same type.
	Скопированный = А.Скопировать();
	Скопированный.Добавить(100);
КонецПроцедуры
